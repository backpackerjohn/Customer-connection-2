rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isNoteAuthor(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Customer Validation ---
    function isValidCustomer(data) {
      return (data.get('status', 'lead') in ['active', 'inactive', 'lead'])
        && (data.get('hasTradeIn', false) is bool)
        && (data.get('stillOwe', false) is bool)
        && (data.get('payingCash', false) is bool)

        // Personal info
        && (!('firstName' in data) || (data.firstName is string && data.firstName.size() <= 100))
        && (!('middleInitial' in data) || (data.middleInitial is string && data.middleInitial.size() <= 10))
        && (!('lastName' in data) || (data.lastName is string && data.lastName.size() <= 100))
        && (!('dob' in data) || (data.dob is string && data.dob.size() <= 20))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('address' in data) || (data.address is string && data.address.size() <= 200))
        && (!('city' in data) || (data.city is string && data.city.size() <= 100))
        && (!('state' in data) || (data.state is string && data.state.size() <= 50))
        && (!('zip' in data) || (data.zip is string && data.zip.size() <= 20))

        // License + Vehicle
        && (!('dlNumber' in data) || (data.dlNumber is string && data.dlNumber.size() <= 50))
        && (!('dlState' in data) || (data.dlState is string && data.dlState.size() <= 50))
        && (!('dlExpiration' in data) || (data.dlExpiration is string && data.dlExpiration.size() <= 20))
        && (!('dlImageUrl' in data) || (data.dlImageUrl is string && data.dlImageUrl.size() <= 1024))
        && (!('vehicleStock' in data) || (data.vehicleStock is string && data.vehicleStock.size() <= 50))
        && (!('vehicleYear' in data) || (data.vehicleYear is string && data.vehicleYear.size() <= 10))
        && (!('vehicleMake' in data) || (data.vehicleMake is string && data.vehicleMake.size() <= 50))
        && (!('vehicleModel' in data) || (data.vehicleModel is string && data.vehicleModel.size() <= 50))
        && (!('vehicleVin' in data) || (data.vehicleVin is string && data.vehicleVin.size() <= 50))
        && (!('vehicleMiles' in data) || (data.vehicleMiles is string && data.vehicleMiles.size() <= 20))

        // Insurance + Trade
        && (!('insuranceCompany' in data) || (data.insuranceCompany is string && data.insuranceCompany.size() <= 100))
        && (!('insuranceImageUrl' in data) || (data.insuranceImageUrl is string && data.insuranceImageUrl.size() <= 1024))
        && (!('agentName' in data) || (data.agentName is string && data.agentName.size() <= 100))
        && (!('tradeYear' in data) || (data.tradeYear is string && data.tradeYear.size() <= 10))
        && (!('tradeMake' in data) || (data.tradeMake is string && data.tradeMake.size() <= 50))
        && (!('tradeModel' in data) || (data.tradeModel is string && data.tradeModel.size() <= 50))
        && (!('tradeTrim' in data) || (data.tradeTrim is string && data.tradeTrim.size() <= 50))
        && (!('tradeMileage' in data) || (data.tradeMileage is string && data.tradeMileage.size() <= 20))
        && (!('tradeVin' in data) || (data.tradeVin is string && data.tradeVin.size() <= 50))

        // Finance + Goals
        && (!('lienholder' in data) || (data.lienholder is string && data.lienholder.size() <= 100))
        && (!('payoffAmount' in data) || (data.payoffAmount is string && data.payoffAmount.size() <= 20))
        && (!('monthlyPayment' in data) || (data.monthlyPayment is string && data.monthlyPayment.size() <= 20))
        && (!('monthsRemaining' in data) || (data.monthsRemaining is string && data.monthsRemaining.size() <= 20))
        && (!('goalsMonthlyPayment' in data) || (data.goalsMonthlyPayment is string && data.goalsMonthlyPayment.size() <= 50))
        && (!('goalsMoneyDown' in data) || (data.goalsMoneyDown is string && data.goalsMoneyDown.size() <= 20))
        && (!('goalsCreditScore' in data) || (data.goalsCreditScore is string && data.goalsCreditScore.size() <= 20))
        && (!('customerDesiredTradeValue' in data) || (data.customerDesiredTradeValue is string && data.customerDesiredTradeValue.size() <= 20))

        // Trade values (low/high + per-condition tiers + metadata)
        && (!('tradeValueLow' in data) || (data.tradeValueLow is string && data.tradeValueLow.size() <= 20))
        && (!('tradeValueHigh' in data) || (data.tradeValueHigh is string && data.tradeValueHigh.size() <= 20))
        && (!('tradeValueExcellentLow' in data) || (data.tradeValueExcellentLow is string && data.tradeValueExcellentLow.size() <= 20))
        && (!('tradeValueExcellentHigh' in data) || (data.tradeValueExcellentHigh is string && data.tradeValueExcellentHigh.size() <= 20))
        && (!('tradeValueVeryGoodLow' in data) || (data.tradeValueVeryGoodLow is string && data.tradeValueVeryGoodLow.size() <= 20))
        && (!('tradeValueVeryGoodHigh' in data) || (data.tradeValueVeryGoodHigh is string && data.tradeValueVeryGoodHigh.size() <= 20))
        && (!('tradeValueGoodLow' in data) || (data.tradeValueGoodLow is string && data.tradeValueGoodLow.size() <= 20))
        && (!('tradeValueGoodHigh' in data) || (data.tradeValueGoodHigh is string && data.tradeValueGoodHigh.size() <= 20))
        && (!('tradeValueFairLow' in data) || (data.tradeValueFairLow is string && data.tradeValueFairLow.size() <= 20))
        && (!('tradeValueFairHigh' in data) || (data.tradeValueFairHigh is string && data.tradeValueFairHigh.size() <= 20))
        && (!('tradeValueSource' in data) || (data.tradeValueSource is string && data.tradeValueSource.size() <= 100))
        && (!('tradeValueCondition' in data) || (data.tradeValueCondition is string && data.tradeValueCondition.size() <= 20))
        && (!('tradeValueAt' in data) || (data.tradeValueAt is string && data.tradeValueAt.size() <= 30))

        // Reminders
        && (!('lastContactedAt' in data) || (data.lastContactedAt is string && data.lastContactedAt.size() <= 30))
        && (!('nextCadenceDue' in data) || (data.nextCadenceDue is string && data.nextCadenceDue.size() <= 30))
        && (!('manualReminders' in data) || (data.manualReminders is list && data.manualReminders.size() <= 50))
        && (!('purchaseDate' in data) || (data.purchaseDate is string && data.purchaseDate.size() <= 30))
        && (!('referralAskedAt' in data) || (data.referralAskedAt is string && data.referralAskedAt.size() <= 30));
    }

    function isValidNote(data) {
      return data.content is string && data.content.size() <= 5000
        && data.type in ['manual', 'ai', 'transcript']
        && data.authorId == request.auth.uid;
    }

    function isValidContact(data) {
      let note = data.get('note', '');
      let attestedAt = data.get('attestedAt', '');
      return data.authorId == request.auth.uid
        && data.kinds is list
        && data.kinds.size() <= 10
        && note is string
        && note.size() <= 1000
        && attestedAt is string
        && attestedAt.size() <= 30;
    }

    // --- Collection Routes ---
    match /customers/{customerId} {
      allow get: if isValidId(customerId) && isOwner(existing());
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(customerId)
        && isValidCustomer(incoming())
        && incoming().keys().hasOnly([
          'firstName', 'middleInitial', 'lastName', 'dob', 'phone', 'email', 'address', 'city', 'state', 'zip',
          'dlNumber', 'dlState', 'dlExpiration', 'dlImageUrl', 'vehicleStock', 'vehicleYear', 'vehicleMake',
          'vehicleModel', 'vehicleVin', 'vehicleMiles', 'insuranceCompany', 'insuranceImageUrl', 'agentName',
          'hasTradeIn', 'stillOwe', 'payingCash', 'tradeYear', 'tradeMake', 'tradeModel', 'tradeTrim', 'tradeMileage',
          'tradeVin', 'lienholder', 'payoffAmount', 'monthlyPayment',
          'monthsRemaining', 'goalsMonthlyPayment', 'goalsMoneyDown', 'goalsCreditScore',
          'tradeValueLow', 'tradeValueHigh',
          'tradeValueExcellentLow', 'tradeValueExcellentHigh',
          'tradeValueVeryGoodLow', 'tradeValueVeryGoodHigh',
          'tradeValueGoodLow', 'tradeValueGoodHigh',
          'tradeValueFairLow', 'tradeValueFairHigh',
          'tradeValueSource', 'tradeValueCondition',
          'tradeValueAt', 'customerDesiredTradeValue', 'status', 'updatedAt',
          'createdBy', 'createdAt', 'lastContactedAt', 'nextCadenceDue', 'manualReminders', 'purchaseDate', 'referralAskedAt'
        ])
        && incoming().createdAt == request.time
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
        && (incoming().createdBy == request.auth.uid);
        
      allow update: if isSignedIn()
        && isValidId(customerId)
        && (isOwner(existing()) || existing().createdBy == null) // Handle legacy docs without createdBy
        && isValidCustomer(incoming())
        // Immutable check
        && (incoming().get('createdAt', existing().createdAt) == existing().createdAt)
        && (incoming().get('createdBy', existing().createdBy) == existing().createdBy)
        // Action-Based Pattern
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'firstName', 'middleInitial', 'lastName', 'dob', 'phone', 'email', 'address', 'city', 'state', 'zip',
            'dlNumber', 'dlState', 'dlExpiration', 'dlImageUrl', 'vehicleStock', 'vehicleYear', 'vehicleMake',
            'vehicleModel', 'vehicleVin', 'vehicleMiles', 'insuranceCompany', 'insuranceImageUrl', 'agentName',
            'hasTradeIn', 'stillOwe', 'payingCash', 'tradeYear', 'tradeMake', 'tradeModel', 'tradeTrim', 'tradeMileage',
            'tradeVin', 'lienholder', 'payoffAmount', 'monthlyPayment',
            'monthsRemaining', 'goalsMonthlyPayment', 'goalsMoneyDown', 'goalsCreditScore',
            'tradeValueLow', 'tradeValueHigh',
            'tradeValueExcellentLow', 'tradeValueExcellentHigh',
            'tradeValueVeryGoodLow', 'tradeValueVeryGoodHigh',
            'tradeValueGoodLow', 'tradeValueGoodHigh',
            'tradeValueFairLow', 'tradeValueFairHigh',
            'tradeValueSource', 'tradeValueCondition',
            'tradeValueAt', 'customerDesiredTradeValue', 'status', 'updatedAt',
            'createdBy', 'createdAt', 'lastContactedAt', 'nextCadenceDue', 'manualReminders', 'purchaseDate', 'referralAskedAt'
          ])
        )
        && (incoming().get('updatedAt', request.time) == request.time);

      allow delete: if isValidId(customerId) && isOwner(existing());

      // Notes Subcollection
      match /notes/{noteId} {
        allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow get: if isValidId(noteId) && isNoteAuthor(resource.data);
        allow create: if isValidId(noteId) 
          && isValidNote(incoming())
          && get(/databases/$(database)/documents/customers/$(customerId)).data.createdBy == request.auth.uid
          && incoming().createdAt == request.time;
        allow update, delete: if isValidId(noteId) && isNoteAuthor(existing());
      }

      // Contacts Subcollection
      match /contacts/{contactId} {
        allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow get: if isValidId(contactId) && isSignedIn() && resource.data.authorId == request.auth.uid;
        allow create: if isValidId(contactId)
          && isValidContact(incoming())
          && get(/databases/$(database)/documents/customers/$(customerId)).data.createdBy == request.auth.uid
          && incoming().at == request.time;
        allow update, delete: if isValidId(contactId) && isSignedIn() && existing().authorId == request.auth.uid;
      }
    }
  }
}
