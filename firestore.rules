rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isNoteAuthor(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Customer Validation ---
    function isValidCustomer(data) {
      return (data.get('status', 'lead') in ['active', 'inactive', 'lead'])
        && (data.get('hasTradeIn', false) is bool)
        && (data.get('stillOwe', false) is bool)
        && (data.get('payingCash', false) is bool)
        
        // Type & Size Guards - Only check if field is present or use default string to avoid null issues
        && (data.get('firstName', '') is string && data.get('firstName', '').size() <= 100)
        && (data.get('lastName', '') is string && data.get('lastName', '').size() <= 100)
        && (data.get('middleInitial', '') is string && data.get('middleInitial', '').size() <= 10)
        && (data.get('phone', '') is string && data.get('phone', '').size() <= 20)
        && (data.get('email', '') is string && data.get('email', '').size() <= 200)
        && (data.get('dob', '') is string && data.get('dob', '').size() <= 20)
        && (data.get('address', '') is string && data.get('address', '').size() <= 200)
        && (data.get('city', '') is string && data.get('city', '').size() <= 100)
        && (data.get('state', '') is string && data.get('state', '').size() <= 50)
        && (data.get('zip', '') is string && data.get('zip', '').size() <= 20)
        && (data.get('dlNumber', '') is string && data.get('dlNumber', '').size() <= 50)
        && (data.get('dlState', '') is string && data.get('dlState', '').size() <= 50)
        && (data.get('dlExpiration', '') is string && data.get('dlExpiration', '').size() <= 20)
        && (data.get('dlImageUrl', '') is string && data.get('dlImageUrl', '').size() <= 1024)
        && (data.get('vehicleStock', '') is string && data.get('vehicleStock', '').size() <= 50)
        && (data.get('vehicleYear', '') is string && data.get('vehicleYear', '').size() <= 10)
        && (data.get('vehicleMake', '') is string && data.get('vehicleMake', '').size() <= 50)
        && (data.get('vehicleModel', '') is string && data.get('vehicleModel', '').size() <= 50)
        && (data.get('vehicleVin', '') is string && data.get('vehicleVin', '').size() <= 50)
        && (data.get('vehicleMiles', '') is string && data.get('vehicleMiles', '').size() <= 20)
        && (data.get('insuranceCompany', '') is string && data.get('insuranceCompany', '').size() <= 100)
        && (data.get('insuranceImageUrl', '') is string && data.get('insuranceImageUrl', '').size() <= 1024)
        && (data.get('agentName', '') is string && data.get('agentName', '').size() <= 100)
        && (data.get('tradeYear', '') is string && data.get('tradeYear', '').size() <= 10)
        && (data.get('tradeMake', '') is string && data.get('tradeMake', '').size() <= 50)
        && (data.get('tradeModel', '') is string && data.get('tradeModel', '').size() <= 50)
        && (data.get('tradeTrim', '') is string && data.get('tradeTrim', '').size() <= 50)
        && (data.get('tradeMileage', '') is string && data.get('tradeMileage', '').size() <= 20)
        && (data.get('tradeVin', '') is string && data.get('tradeVin', '').size() <= 50)
        && (data.get('lienholder', '') is string && data.get('lienholder', '').size() <= 100)
        && (data.get('payoffAmount', '') is string && data.get('payoffAmount', '').size() <= 20)
        && (data.get('monthlyPayment', '') is string && data.get('monthlyPayment', '').size() <= 20)
        && (data.get('monthsRemaining', '') is string && data.get('monthsRemaining', '').size() <= 20)
        && (data.get('goalsMonthlyPayment', '') is string && data.get('goalsMonthlyPayment', '').size() <= 50)
        && (data.get('goalsMoneyDown', '') is string && data.get('goalsMoneyDown', '').size() <= 20)
        && (data.get('goalsCreditScore', '') is string && data.get('goalsCreditScore', '').size() <= 20)
        && (data.get('tradeValueLow', '') is string && data.get('tradeValueLow', '').size() <= 20)
        && (data.get('tradeValueHigh', '') is string && data.get('tradeValueHigh', '').size() <= 20)
        && (data.get('tradeValueExcellentLow', '') is string && data.get('tradeValueExcellentLow', '').size() <= 20)
        && (data.get('tradeValueExcellentHigh', '') is string && data.get('tradeValueExcellentHigh', '').size() <= 20)
        && (data.get('tradeValueVeryGoodLow', '') is string && data.get('tradeValueVeryGoodLow', '').size() <= 20)
        && (data.get('tradeValueVeryGoodHigh', '') is string && data.get('tradeValueVeryGoodHigh', '').size() <= 20)
        && (data.get('tradeValueGoodLow', '') is string && data.get('tradeValueGoodLow', '').size() <= 20)
        && (data.get('tradeValueGoodHigh', '') is string && data.get('tradeValueGoodHigh', '').size() <= 20)
        && (data.get('tradeValueFairLow', '') is string && data.get('tradeValueFairLow', '').size() <= 20)
        && (data.get('tradeValueFairHigh', '') is string && data.get('tradeValueFairHigh', '').size() <= 20)
        && (data.get('tradeValueSource', '') is string && data.get('tradeValueSource', '').size() <= 100)
        && (data.get('tradeValueCondition', '') is string && data.get('tradeValueCondition', '').size() <= 20)
        && (data.get('tradeValueAt', '') is string && data.get('tradeValueAt', '').size() <= 30)
        && (data.get('customerDesiredTradeValue', '') is string && data.get('customerDesiredTradeValue', '').size() <= 20);
    }

    function isValidNote(data) {
      return data.content is string && data.content.size() <= 5000
        && data.type in ['manual', 'ai', 'transcript']
        && data.authorId == request.auth.uid;
    }

    // --- Collection Routes ---
    match /customers/{customerId} {
      allow get: if isValidId(customerId) && isOwner(existing());
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(customerId)
        && isValidCustomer(incoming())
        && incoming().createdAt == request.time
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
        && (incoming().createdBy == request.auth.uid);
        
      allow update: if isSignedIn()
        && isValidId(customerId)
        && (isOwner(existing()) || existing().createdBy == null) // Handle legacy docs without createdBy
        && isValidCustomer(incoming())
        // Immutable check
        && (incoming().get('createdAt', existing().createdAt) == existing().createdAt)
        && (incoming().get('createdBy', existing().createdBy) == existing().createdBy)
        // Action-Based Pattern
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'firstName', 'middleInitial', 'lastName', 'dob', 'phone', 'email', 'address', 'city', 'state', 'zip',
            'dlNumber', 'dlState', 'dlExpiration', 'dlImageUrl', 'vehicleStock', 'vehicleYear', 'vehicleMake',
            'vehicleModel', 'vehicleVin', 'vehicleMiles', 'insuranceCompany', 'insuranceImageUrl', 'agentName',
            'hasTradeIn', 'stillOwe', 'payingCash', 'tradeYear', 'tradeMake', 'tradeModel', 'tradeTrim', 'tradeMileage',
            'tradeVin', 'lienholder', 'payoffAmount', 'monthlyPayment',
            'monthsRemaining', 'goalsMonthlyPayment', 'goalsMoneyDown', 'goalsCreditScore',
            'tradeValueLow', 'tradeValueHigh',
            'tradeValueExcellentLow', 'tradeValueExcellentHigh',
            'tradeValueVeryGoodLow', 'tradeValueVeryGoodHigh',
            'tradeValueGoodLow', 'tradeValueGoodHigh',
            'tradeValueFairLow', 'tradeValueFairHigh',
            'tradeValueSource', 'tradeValueCondition',
            'tradeValueAt', 'customerDesiredTradeValue', 'status', 'updatedAt',
            'createdBy', 'createdAt'
          ])
        )
        && (incoming().get('updatedAt', request.time) == request.time);

      allow delete: if isValidId(customerId) && isOwner(existing());

      // Notes Subcollection
      match /notes/{noteId} {
        allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow get: if isValidId(noteId) && isNoteAuthor(resource.data);
        allow create: if isValidId(noteId) 
          && isValidNote(incoming())
          && get(/databases/$(database)/documents/customers/$(customerId)).data.createdBy == request.auth.uid
          && incoming().createdAt == request.time;
        allow update, delete: if isValidId(noteId) && isNoteAuthor(existing());
      }
    }
  }
}
