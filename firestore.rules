rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isNoteAuthor(data) {
      return isSignedIn() && data.authorId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Customer Validation ---
    function isValidCustomer(data) {
      let firstName = data.get('firstName', '');
      let lastName = data.get('lastName', '');
      let middleInitial = data.get('middleInitial', '');
      let phone = data.get('phone', '');
      let email = data.get('email', '');
      let dob = data.get('dob', '');
      let address = data.get('address', '');
      let city = data.get('city', '');
      let state = data.get('state', '');
      let zip = data.get('zip', '');
      let dlNumber = data.get('dlNumber', '');
      let dlState = data.get('dlState', '');
      let dlExpiration = data.get('dlExpiration', '');
      let dlImageUrl = data.get('dlImageUrl', '');
      let vehicleStock = data.get('vehicleStock', '');
      let vehicleYear = data.get('vehicleYear', '');
      let vehicleMake = data.get('vehicleMake', '');
      let vehicleModel = data.get('vehicleModel', '');
      let vehicleVin = data.get('vehicleVin', '');
      let vehicleMiles = data.get('vehicleMiles', '');
      let insuranceCompany = data.get('insuranceCompany', '');
      let insuranceImageUrl = data.get('insuranceImageUrl', '');
      let agentName = data.get('agentName', '');
      let tradeYear = data.get('tradeYear', '');
      let tradeMake = data.get('tradeMake', '');
      let tradeModel = data.get('tradeModel', '');
      let tradeTrim = data.get('tradeTrim', '');
      let tradeMileage = data.get('tradeMileage', '');
      let tradeVin = data.get('tradeVin', '');
      let lienholder = data.get('lienholder', '');
      let payoffAmount = data.get('payoffAmount', '');
      let monthlyPayment = data.get('monthlyPayment', '');
      let monthsRemaining = data.get('monthsRemaining', '');
      let goalsMonthlyPayment = data.get('goalsMonthlyPayment', '');
      let goalsMoneyDown = data.get('goalsMoneyDown', '');
      let goalsCreditScore = data.get('goalsCreditScore', '');
      let tradeValueLow = data.get('tradeValueLow', '');
      let tradeValueHigh = data.get('tradeValueHigh', '');
      let tradeValueExcellentLow = data.get('tradeValueExcellentLow', '');
      let tradeValueExcellentHigh = data.get('tradeValueExcellentHigh', '');
      let tradeValueVeryGoodLow = data.get('tradeValueVeryGoodLow', '');
      let tradeValueVeryGoodHigh = data.get('tradeValueVeryGoodHigh', '');
      let tradeValueGoodLow = data.get('tradeValueGoodLow', '');
      let tradeValueGoodHigh = data.get('tradeValueGoodHigh', '');
      let tradeValueFairLow = data.get('tradeValueFairLow', '');
      let tradeValueFairHigh = data.get('tradeValueFairHigh', '');
      let tradeValueSource = data.get('tradeValueSource', '');
      let tradeValueCondition = data.get('tradeValueCondition', '');
      let tradeValueAt = data.get('tradeValueAt', '');
      let customerDesiredTradeValue = data.get('customerDesiredTradeValue', '');
      let lastContactedAt = data.get('lastContactedAt', '');
      let nextCadenceDue = data.get('nextCadenceDue', '');
      let manualReminders = data.get('manualReminders', []);
      let purchaseDate = data.get('purchaseDate', '');
      let referralAskedAt = data.get('referralAskedAt', '');

      return (data.get('status', 'lead') in ['active', 'inactive', 'lead'])
        && (data.get('hasTradeIn', false) is bool)
        && (data.get('stillOwe', false) is bool)
        && (data.get('payingCash', false) is bool)
        
        // Type & Size Guards - Only check if field is present or use default string to avoid null issues
        && (firstName is string && firstName.size() <= 100)
        && (lastName is string && lastName.size() <= 100)
        && (middleInitial is string && middleInitial.size() <= 10)
        && (phone is string && phone.size() <= 20)
        && (email is string && email.size() <= 200)
        && (dob is string && dob.size() <= 20)
        && (address is string && address.size() <= 200)
        && (city is string && city.size() <= 100)
        && (state is string && state.size() <= 50)
        && (zip is string && zip.size() <= 20)
        && (dlNumber is string && dlNumber.size() <= 50)
        && (dlState is string && dlState.size() <= 50)
        && (dlExpiration is string && dlExpiration.size() <= 20)
        && (dlImageUrl is string && dlImageUrl.size() <= 1024)
        && (vehicleStock is string && vehicleStock.size() <= 50)
        && (vehicleYear is string && vehicleYear.size() <= 10)
        && (vehicleMake is string && vehicleMake.size() <= 50)
        && (vehicleModel is string && vehicleModel.size() <= 50)
        && (vehicleVin is string && vehicleVin.size() <= 50)
        && (vehicleMiles is string && vehicleMiles.size() <= 20)
        && (insuranceCompany is string && insuranceCompany.size() <= 100)
        && (insuranceImageUrl is string && insuranceImageUrl.size() <= 1024)
        && (agentName is string && agentName.size() <= 100)
        && (tradeYear is string && tradeYear.size() <= 10)
        && (tradeMake is string && tradeMake.size() <= 50)
        && (tradeModel is string && tradeModel.size() <= 50)
        && (tradeTrim is string && tradeTrim.size() <= 50)
        && (tradeMileage is string && tradeMileage.size() <= 20)
        && (tradeVin is string && tradeVin.size() <= 50)
        && (lienholder is string && lienholder.size() <= 100)
        && (payoffAmount is string && payoffAmount.size() <= 20)
        && (monthlyPayment is string && monthlyPayment.size() <= 20)
        && (monthsRemaining is string && monthsRemaining.size() <= 20)
        && (goalsMonthlyPayment is string && goalsMonthlyPayment.size() <= 50)
        && (goalsMoneyDown is string && goalsMoneyDown.size() <= 20)
        && (goalsCreditScore is string && goalsCreditScore.size() <= 20)
        && (tradeValueLow is string && tradeValueLow.size() <= 20)
        && (tradeValueHigh is string && tradeValueHigh.size() <= 20)
        && (tradeValueExcellentLow is string && tradeValueExcellentLow.size() <= 20)
        && (tradeValueExcellentHigh is string && tradeValueExcellentHigh.size() <= 20)
        && (tradeValueVeryGoodLow is string && tradeValueVeryGoodLow.size() <= 20)
        && (tradeValueVeryGoodHigh is string && tradeValueVeryGoodHigh.size() <= 20)
        && (tradeValueGoodLow is string && tradeValueGoodLow.size() <= 20)
        && (tradeValueGoodHigh is string && tradeValueGoodHigh.size() <= 20)
        && (tradeValueFairLow is string && tradeValueFairLow.size() <= 20)
        && (tradeValueFairHigh is string && tradeValueFairHigh.size() <= 20)
        && (tradeValueSource is string && tradeValueSource.size() <= 100)
        && (tradeValueCondition is string && tradeValueCondition.size() <= 20)
        && (tradeValueAt is string && tradeValueAt.size() <= 30)
        && (customerDesiredTradeValue is string && customerDesiredTradeValue.size() <= 20)
        && (lastContactedAt is string && lastContactedAt.size() <= 30)
        && (nextCadenceDue is string && nextCadenceDue.size() <= 30)
        && (manualReminders is list && manualReminders.size() <= 50)
        && (purchaseDate is string && purchaseDate.size() <= 30)
        && (referralAskedAt is string && referralAskedAt.size() <= 30);
    }

    function isValidNote(data) {
      return data.content is string && data.content.size() <= 5000
        && data.type in ['manual', 'ai', 'transcript']
        && data.authorId == request.auth.uid;
    }

    function isValidContact(data) {
      let note = data.get('note', '');
      let attestedAt = data.get('attestedAt', '');
      return data.authorId == request.auth.uid
        && data.kinds is list
        && data.kinds.size() <= 10
        && note is string
        && note.size() <= 1000
        && attestedAt is string
        && attestedAt.size() <= 30;
    }

    // --- Collection Routes ---
    match /customers/{customerId} {
      allow get: if isValidId(customerId) && isOwner(existing());
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(customerId)
        && isValidCustomer(incoming())
        && incoming().createdAt == request.time
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
        && (incoming().createdBy == request.auth.uid);
        
      allow update: if isSignedIn()
        && isValidId(customerId)
        && (isOwner(existing()) || existing().createdBy == null) // Handle legacy docs without createdBy
        && isValidCustomer(incoming())
        // Immutable check
        && (incoming().get('createdAt', existing().createdAt) == existing().createdAt)
        && (incoming().get('createdBy', existing().createdBy) == existing().createdBy)
        // Action-Based Pattern
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'firstName', 'middleInitial', 'lastName', 'dob', 'phone', 'email', 'address', 'city', 'state', 'zip',
            'dlNumber', 'dlState', 'dlExpiration', 'dlImageUrl', 'vehicleStock', 'vehicleYear', 'vehicleMake',
            'vehicleModel', 'vehicleVin', 'vehicleMiles', 'insuranceCompany', 'insuranceImageUrl', 'agentName',
            'hasTradeIn', 'stillOwe', 'payingCash', 'tradeYear', 'tradeMake', 'tradeModel', 'tradeTrim', 'tradeMileage',
            'tradeVin', 'lienholder', 'payoffAmount', 'monthlyPayment',
            'monthsRemaining', 'goalsMonthlyPayment', 'goalsMoneyDown', 'goalsCreditScore',
            'tradeValueLow', 'tradeValueHigh',
            'tradeValueExcellentLow', 'tradeValueExcellentHigh',
            'tradeValueVeryGoodLow', 'tradeValueVeryGoodHigh',
            'tradeValueGoodLow', 'tradeValueGoodHigh',
            'tradeValueFairLow', 'tradeValueFairHigh',
            'tradeValueSource', 'tradeValueCondition',
            'tradeValueAt', 'customerDesiredTradeValue', 'status', 'updatedAt',
            'createdBy', 'createdAt', 'lastContactedAt', 'nextCadenceDue', 'manualReminders', 'purchaseDate', 'referralAskedAt'
          ])
        )
        && (incoming().get('updatedAt', request.time) == request.time);

      allow delete: if isValidId(customerId) && isOwner(existing());

      // Notes Subcollection
      match /notes/{noteId} {
        allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow get: if isValidId(noteId) && isNoteAuthor(resource.data);
        allow create: if isValidId(noteId) 
          && isValidNote(incoming())
          && get(/databases/$(database)/documents/customers/$(customerId)).data.createdBy == request.auth.uid
          && incoming().createdAt == request.time;
        allow update, delete: if isValidId(noteId) && isNoteAuthor(existing());
      }

      // Contacts Subcollection
      match /contacts/{contactId} {
        allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow get: if isValidId(contactId) && isSignedIn() && resource.data.authorId == request.auth.uid;
        allow create: if isValidId(contactId)
          && isValidContact(incoming())
          && get(/databases/$(database)/documents/customers/$(customerId)).data.createdBy == request.auth.uid
          && incoming().at == request.time;
        allow update, delete: if isValidId(contactId) && isSignedIn() && existing().authorId == request.auth.uid;
      }
    }
  }
}
